  created_at                                         DateTime     @default(now())
  utilizadores_avaliacoes_avaliado_idToutilizadores  utilizadores @relation("avaliacoes_avaliado_idToutilizadores", fields: [avaliado_id], references: [id], onDelete: Cascade)
  utilizadores_avaliacoes_avaliador_idToutilizadores utilizadores @relation("avaliacoes_avaliador_idToutilizadores", fields: [avaliador_id], references: [id], onDelete: Cascade)
  fretes                                             fretes       @relation(fields: [frete_id], references: [id], onDelete: Cascade)

  @@index([avaliado_id])
  @@index([avaliador_id])
  @@index([frete_id])
}

