generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model alertas_configurados {
  id           String       @id
  usuario_id   String
  tipo_alerta  tipo_alerta
  condicoes    Json
  ativo        Boolean      @default(true)
  created_at   DateTime     @default(now())
  updated_at   DateTime
  utilizadores utilizadores @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([ativo])
  @@index([tipo_alerta])
  @@index([usuario_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model auditoria_dados_sensiveis {
  id                  BigInt        @id @default(autoincrement())
  tabela              String        @db.VarChar(50)
  registro_id         String
  campo_alterado      String        @db.VarChar(50)
  valor_anterior      String?
  valor_novo          String?
  usuario_responsavel String?
  ip_address          String?       @db.VarChar(45)
  created_at          DateTime      @default(now())
  utilizadores        utilizadores? @relation(fields: [usuario_responsavel], references: [id])

  @@index([created_at])
  @@index([tabela, registro_id])
  @@index([usuario_responsavel])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model avaliacoes {
  id                                                 String       @id
