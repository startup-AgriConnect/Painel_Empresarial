  produtos              produtos        @relation(fields: [produto_id], references: [id])
  produtores            produtores      @relation(fields: [produtor_id], references: [id], onDelete: Cascade)

  @@index([comprador_id])
  @@index([data_inicio, data_fim])
  @@index([deleted_at])
  @@index([produto_id])
  @@index([produtor_id])
  @@index([status])
}

