# Environment
NODE_ENV=development

# API Configuration
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=10000

# Usar dados mock (true = desenvolvimento sem backend, false = API real)
VITE_USE_MOCK=true

# Google Earth Engine (if integrated)
VITE_GEE_API_KEY=your_gee_api_key_here

# Authentication
VITE_AUTH_TOKEN_KEY=agriconnect_auth_token

# Feature Flags
VITE_ENABLE_AI_PREDICTIONS=true
VITE_ENABLE_BLOCKCHAIN=true
VITE_ENABLE_GEOINTELIGENCIA=true

# Analytics (optional)
VITE_ANALYTICS_ID=

# Sentry Error Tracking (optional)
VITE_SENTRY_DSN=
